[Unit]
Description=Flask Dashboard Service
After=network.target

[Service]
User=ec2-user
Group=ec2-user
WorkingDirectory=/home/ec2-user/flask_service
EnvironmentFile=/home/ec2-user/flask_service/.env
ExecStart=/home/ec2-user/flask_service/.venv/bin/gunicorn --workers 2 --bind 127.0.0.1:5000 wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
